{
  "info": {
    "_postman_id": "3dc7fa83-d6eb-47a5-b522-6f4fe2e42b31",
    "name": "Trinetra API Full Runner",
    "description": "End-to-end Postman collection for Student Assessment Platform API. It creates test data, executes admin and student flows, runs practice and scheduled tests, and performs cleanup.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const bootstrapRequest = '01. Super Admin Login';",
          "",
          "function setIfMissing(key, value) {",
          "  if (!pm.collectionVariables.get(key)) {",
          "    pm.collectionVariables.set(key, value);",
          "  }",
          "}",
          "",
          "function initializeRunData() {",
          "  const runId = `${Date.now()}${Math.floor(Math.random() * 1000)}`;",
          "  const now = Date.now();",
          "  const start = new Date(now + 8000).toISOString();",
          "  const end = new Date(now + 60 * 60 * 1000).toISOString();",
          "",
          "  pm.collectionVariables.set('runId', runId);",
          "  setIfMissing('state', 'Telangana');",
          "  setIfMissing('college', 'JNTUH');",
          "  setIfMissing('branch', 'CSE');",
          "  setIfMissing('year_of_passing', '2026');",
          "  setIfMissing('student_password', 'SecurePass@123');",
          "  setIfMissing('student_new_password', 'NewSecurePass@123');",
          "  setIfMissing('admin_password', 'AdminPass@123');",
          "  setIfMissing('practice_topic_slug', 'percentages');",
          "  setIfMissing('practice_topic_title', 'Percentages');",
          "",
          "  pm.collectionVariables.set('student_primary_email', `student.primary.${runId}@example.com`);",
          "  pm.collectionVariables.set('student_secondary_email', `student.secondary.${runId}@example.com`);",
          "  pm.collectionVariables.set('student_reject_email', `student.reject.${runId}@example.com`);",
          "  pm.collectionVariables.set('student_bulk_reject_email', `student.bulkreject.${runId}@example.com`);",
          "  pm.collectionVariables.set('student_approve_all_email', `student.approveall.${runId}@example.com`);",
          "  pm.collectionVariables.set('admin_email', `admin.${runId}@example.com`);",
          "  pm.collectionVariables.set('test_title_practice', `Practice Test ${runId}`);",
          "  pm.collectionVariables.set('test_title_scheduled', `Scheduled Test ${runId}`);",
          "  pm.collectionVariables.set('scheduled_start', start);",
          "  pm.collectionVariables.set('scheduled_end', end);",
          "",
          "  [",
          "    'super_admin_token',",
          "    'admin_token',",
          "    'student_token',",
          "    'student_primary_id',",
          "    'student_secondary_id',",
          "    'student_reject_id',",
          "    'student_bulk_reject_id',",
          "    'student_approve_all_id',",
          "    'practice_exam_id',",
          "    'scheduled_test_id'",
          "  ].forEach((k) => pm.collectionVariables.unset(k));",
          "}",
          "",
          "if (pm.info.requestName === bootstrapRequest && pm.info.iteration === 0) {",
          "  initializeRunData();",
          "} else {",
          "  setIfMissing('state', 'Telangana');",
          "  setIfMissing('college', 'JNTUH');",
          "  setIfMissing('branch', 'CSE');",
          "  setIfMissing('year_of_passing', '2026');",
          "  setIfMissing('student_password', 'SecurePass@123');",
          "  setIfMissing('student_new_password', 'NewSecurePass@123');",
          "  setIfMissing('admin_password', 'AdminPass@123');",
          "  setIfMissing('practice_topic_slug', 'percentages');",
          "  setIfMissing('practice_topic_title', 'Percentages');",
          "}"
        ]
      }
    }
  ],
